<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= company %> — Rental Alat Berat & Logistik</title>

  <!-- SEO -->
  <meta name="description" content="<%= description %>" />
  <meta name="theme-color" content="#0f5d3b" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Open Graph / WhatsApp & sosial media -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content="<%= company %>" />
  <meta property="og:description" content="<%= description %>" />
  <meta property="og:image" content="https://images.unsplash.com/photo-1581094794329-c8112a89af12?auto=format&fit=crop&w=1200&q=80" />

  <!-- Structured data untuk bisnis lokal -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "<%= company %>",
    "description": "<%= description %>",
    "telephone": "<%= phoneDisplay %>",
    "email": "<%= email %>",
    "address": "<%= address %>"
  }
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <!-- Preloader -->
  <div class="preloader" id="preloader">
    <div class="preloader-logo">KM</div>
    <strong>Preparing Site Access</strong>
    <span>Memuat Halaman…</span>
    <div class="preloader-bar"><i></i></div>
  </div>

  <header class="navbar" id="navbar">
    <a href="#home" class="brand">
      <span class="brand-logo">KM</span>
      <span>
        <strong><%= shortName %></strong>
        <small>Jaya Group</small>
      </span>
    </a>

    <button class="menu-btn" id="menuBtn" aria-label="Buka menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

    <nav class="nav-menu" id="navMenu">
      <a href="#home" class="active">Beranda</a>
      <a href="#about">Tentang</a>
      <a href="#advantages">Keunggulan</a>
      <a href="#services">Layanan</a>
      <a href="#projects">Portofolio</a>
      <a href="#contact" class="nav-cta">Hubungi Kami</a>
    </nav>
  </header>

  <main>
    <section class="hero" id="home">
      <div class="hero-bg"></div>

      <div class="hero-content reveal">
        <p class="eyebrow"><%= tagline %></p>
        <h1>Partner Terpercaya Rental Alat Berat & Logistik.</h1>
        <p class="hero-desc">
          <%= company %> menyediakan jasa rental alat berat, transportasi, dan logistik
          di seluruh Sumatera dengan armada lengkap, operator berpengalaman, dan harga kompetitif.
        </p>

        <div class="hero-actions">
          <a href="#services" class="btn primary">Lihat Layanan</a>
          <a href="#about" class="btn secondary">Tentang Kami</a>
        </div>

        <div class="hero-stats">
          <% stats.forEach(function(s){ %>
            <div>
              <strong class="counter" data-target="<%= s.value %>" data-suffix="<%= s.suffix %>">0<%= s.suffix %></strong>
              <span><%= s.label %></span>
            </div>
          <% }); %>
        </div>
      </div>

      <div class="hero-card reveal delay">
        <div class="card-image"></div>
        <div class="floating-badge">
          <strong>100+</strong>
          <span>Armada Siap Jalan</span>
        </div>
      </div>

      <a href="#about" class="scroll-indicator" aria-label="Scroll ke bawah">
        <span>Scroll</span>
        <i class="material-symbols-rounded">expand_more</i>
      </a>
    </section>

    <section class="section about" id="about">
      <div class="section-text reveal">
        <p class="eyebrow dark">Profil Singkat</p>
        <h2>Solusi alat berat & logistik untuk proyek Anda di Sumatera.</h2>
        <p>
          Kami menyediakan penyewaan alat berat dan transportasi dengan armada yang
          terawat, operator bersertifikat, serta layanan yang cepat dan transparan
          untuk mendukung kelancaran setiap proyek.
        </p>
      </div>

      <div class="about-grid">
        <% advantages.slice(0,3).forEach(function(item, i){ %>
          <div class="info-card reveal" style="--i: <%= i %>">
            <i class="material-symbols-rounded card-icon"><%= item.icon %></i>
            <h3><%= item.title %></h3>
            <p><%= item.text %></p>
          </div>
        <% }); %>
      </div>
    </section>

    <section class="section advantages" id="advantages">
      <div class="section-heading reveal">
        <p class="eyebrow dark">Keunggulan</p>
        <h2>Kenapa memilih kami.</h2>
      </div>

      <div class="adv-grid">
        <% advantages.forEach(function(a, i){ %>
          <article class="adv-card reveal" style="--i: <%= i %>">
            <i class="material-symbols-rounded"><%= a.icon %></i>
            <h3><%= a.title %></h3>
            <p><%= a.text %></p>
          </article>
        <% }); %>
      </div>
    </section>

    <section class="section infra" id="infra">
      <div class="infra-text reveal">
        <p class="eyebrow">Infrastruktur</p>
        <h2><%= infra.title %></h2>
        <p class="infra-desc"><%= infra.text %></p>
        <div class="infra-highlights">
          <% infra.highlights.forEach(function(h, i){ %>
            <div class="infra-item" style="--i: <%= i %>">
              <i class="material-symbols-rounded"><%= h.icon %></i>
              <div>
                <strong><%= h.title %></strong>
                <span><%= h.text %></span>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
      <div class="infra-badge reveal delay">
        <strong><%= infra.badge.value %></strong>
        <span><%= infra.badge.label %></span>
      </div>
    </section>

    <section class="section services" id="services">
      <div class="section-heading reveal">
        <p class="eyebrow dark">Layanan Unggulan</p>
        <h2>Solusi lengkap kebutuhan alat berat & logistik.</h2>
      </div>

      <div class="service-grid">
        <% services.forEach(function(s, i){ %>
          <article class="service-card reveal" style="--i: <%= i %>">
            <div class="service-img-wrap">
              <img class="service-img" src="<%= s.image %>" alt="<%= s.alt %>" loading="lazy" />
              <span class="service-tag"><i class="material-symbols-rounded"><%= s.icon %></i></span>
            </div>
            <div class="service-body">
              <h3><%= s.title %></h3>
              <p><%= s.text %></p>
            </div>
          </article>
        <% }); %>
      </div>
    </section>

    <section class="section partners">
      <div class="section-heading reveal" style="text-align:center; margin-inline:auto;">
        <p class="eyebrow dark">Kepercayaan Klien</p>
        <h2>Dipercaya oleh berbagai perusahaan.</h2>
      </div>
      <div class="marquee">
        <div class="marquee-track">
          <% partners.concat(partners).forEach(function(name){ %>
            <div class="partner-logo"><%= name %></div>
          <% }); %>
        </div>
      </div>
    </section>

    <section class="section projects" id="projects">
      <div class="section-heading reveal">
        <p class="eyebrow dark">Portofolio</p>
        <h2>Beberapa pekerjaan yang kami tangani.</h2>
      </div>

      <div class="project-grid">
        <% projects.forEach(function(p, i){ %>
          <div class="project-card reveal" style="--i: <%= i %>">
            <div class="project-img-wrap">
              <img class="project-img" src="<%= p.image %>" alt="<%= p.alt %>" loading="lazy" />
            </div>
            <div class="project-body">
              <h3><%= p.title %></h3>
              <p><%= p.text %></p>
            </div>
          </div>
        <% }); %>
      </div>
    </section>

    <section class="section testimonials" id="testimonials">
      <div class="section-heading reveal">
        <p class="eyebrow dark">Testimoni</p>
        <h2>Apa kata klien kami.</h2>
      </div>
      <div class="testi-grid">
        <% testimonials.forEach(function(t, i){ %>
          <figure class="testi-card reveal" style="--i: <%= i %>">
            <blockquote>“<%= t.text %>”</blockquote>
            <figcaption>
              <strong><%= t.name %></strong>
              <span><%= t.role %></span>
            </figcaption>
          </figure>
        <% }); %>
      </div>
    </section>

    <section class="section faq" id="faq">
      <div class="section-heading reveal">
        <p class="eyebrow dark">FAQ</p>
        <h2>Pertanyaan yang sering diajukan.</h2>
      </div>
      <div class="faq-list">
        <% faq.forEach(function(f){ %>
          <details class="faq-item reveal">
            <summary><%= f.q %><span class="faq-icon">+</span></summary>
            <p><%= f.a %></p>
          </details>
        <% }); %>
      </div>
    </section>

    <section class="cta reveal" id="contact">
      <div class="cta-text">
        <p class="eyebrow">Butuh konsultasi alat berat?</p>
        <h2>Hubungi kami untuk penawaran terbaik.</h2>
        <p>Isi form di bawah atau hubungi langsung untuk konsultasi dan estimasi sewa.</p>
        <ul class="cta-contact">
          <li><i class="material-symbols-rounded">call</i> <%= phoneDisplay %> / <%= phone2Display %></li>
          <li><i class="material-symbols-rounded">mail</i> <%= email %></li>
          <li><i class="material-symbols-rounded">location_on</i> <%= address %></li>
        </ul>
      </div>

      <form class="contact-form" action="/contact" method="POST">
        <% if (sent) { %>
          <p class="form-alert success">Terima kasih! Pesan Anda sudah kami terima.</p>
        <% } %>
        <% if (error) { %>
          <p class="form-alert err"><%= error %></p>
        <% } %>
        <input type="text" name="name" placeholder="Nama Anda" required />
        <input type="email" name="email" placeholder="Email Anda" required />
        <textarea name="message" rows="3" placeholder="Alat yang dibutuhkan & lokasi proyek" required></textarea>
        <div class="form-actions">
          <button type="submit" class="btn white">Kirim Pesan</button>
          <a href="https://wa.me/<%= phone %>?text=Halo%20saya%20ingin%20konsultasi%20alat%20berat" class="btn ghost">Konsultasi WhatsApp</a>
        </div>
      </form>
    </section>
  </main>

  <footer class="footer">
    <div class="footer-col">
      <strong><%= company %></strong>
      <p>Partner terpercaya rental alat berat, transportasi, dan logistik di Sumatera.</p>
      <div class="footer-social">
        <% social.forEach(function(s){ %>
          <a href="<%= s.url %>" target="_blank" rel="noopener"><%= s.label %></a>
        <% }); %>
      </div>
    </div>
    <div class="footer-col">
      <strong>Tautan Cepat</strong>
      <a href="#about">Tentang</a>
      <a href="#advantages">Keunggulan</a>
      <a href="#services">Layanan</a>
      <a href="#projects">Portofolio</a>
    </div>
    <div class="footer-col">
      <strong>Kontak</strong>
      <p>Telp: <%= phoneDisplay %></p>
      <p>Telp: <%= phone2Display %></p>
      <p>Email: <%= email %></p>
      <p>IG: @<%= instagram %></p>
      <p><%= address %></p>
    </div>
    <p class="footer-copy">© <%= year %> KMJ Group. Semua hak dilindungi.</p>
  </footer>

  <a class="wa-float" href="https://wa.me/<%= phone %>?text=Halo%20saya%20ingin%20konsultasi%20alat%20berat" aria-label="Hubungi via WhatsApp">
    <span>WA</span>
  </a>

  <script src="/js/main.js"></script>
</body>
</html>
